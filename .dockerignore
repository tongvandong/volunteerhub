# Keep the Docker build context small & reproducible.
**/bin/
**/obj/
**/out/
**/publish/
artifacts/
**/node_modules/
BaseCore.WebClient/dist/
volunteerhub-frontend/dist/

# Rust build output (rebuilt inside the image)
BaseCore.CertificateWorker/target/

# Local env / secrets — never bake into images
**/.env
.env
*.env.local

# VCS / IDE / OS noise
.git/
.gitignore
.vs/
.vscode/
.idea/
**/*.user
**/.DS_Store

# Tests & docs not needed at runtime
**/TestResults/
playwright-report/
test-results/
