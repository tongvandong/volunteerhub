# VolunteerHub edge / reverse proxy.
#
# SITE_ADDRESS controls the listening address:
#   - default ":80"            -> plain HTTP (use for VPS-by-IP or local testing)
#   - a domain e.g.            -> Caddy automatically provisions a Let's Encrypt certificate
#     "volunteerhub.example.com"  and serves HTTPS (ports 80 + 443 must be reachable).
{$SITE_ADDRESS::80} {
	encode zstd gzip

	# Realtime SignalR hub -> EventService. Caddy upgrades websockets automatically.
	handle /hubs/* {
		reverse_proxy eventservice:8080
	}

	# REST API -> Ocelot API gateway.
	handle /api/* {
		reverse_proxy gateway:8080
	}

	# Single Page App: static assets with history-API fallback to index.html.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
