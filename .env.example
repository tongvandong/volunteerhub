# Copy to .env and edit before running `docker compose up`.
# (.env is git-ignored / docker-ignored — never commit real secrets.)

# --- SQL Server SA password ---------------------------------------------
# Must satisfy SQL Server complexity: >= 8 chars, upper + lower + digit + symbol.
SA_PASSWORD=Ch4ngeMe_Str0ng!

# --- JWT signing key ------------------------------------------------------
# Long random string. All services MUST share the same value to validate tokens.
# Generate e.g.: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# --- Redis password -------------------------------------------------------
REDIS_PASSWORD=Ch4ngeMe_Redis!

# --- Public URL of the site ----------------------------------------------
# Used for CORS and for the verify link encoded into certificate QR codes.
# Local test:   http://localhost
# Production:   https://volunteerhub.example.com
PUBLIC_URL=http://localhost

# --- Caddy listening address ---------------------------------------------
# ":80"  -> plain HTTP (local test, or VPS accessed by raw IP)
# a domain (e.g. "volunteerhub.example.com") -> Caddy auto-provisions HTTPS
SITE_ADDRESS=:80
